{
  "name": "sacred-pixel-dungeon-android",
  "version": "3.3.8",
  "description": "Sacred Pixel Dungeon - Android Capacitor Wrapper",
  "main": "index.js",
  "scripts": {
    "sync": "npx cap sync android",
    "open": "npx cap open android",
